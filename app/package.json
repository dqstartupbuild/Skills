{
  "name": "app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "content:build": "node ./scripts/build-content-collections.mjs",
    "content:watch": "node ./scripts/watch-content-collections.mjs",
    "dev": "node ./scripts/watch-content-collections.mjs & next dev",
    "build": "npm run content:build && next build",
    "start": "next start",
    "lint": "npm run content:build && eslint .",
    "typecheck": "npm run content:build && tsc --noEmit",
    "test": "npm run content:build && vitest run --coverage"
  },
  "dependencies": {
    "@content-collections/core": "^0.15.0",
    "@content-collections/mdx": "^0.2.2",
    "@vercel/analytics": "^2.0.1",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "remark-gfm": "^4.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
