export function getOgOutputAbsolutePath(outputPath: string) {
  return path.join(process.cwd(), "public", outputPath.replace(/^\//, ""));
}

export function getOgTargetBases(): OgTargetBase[] {
  return SAMPLE_TARGETS;
}

export function getOgTargetByKey(key: string) {
  return getOgTargetBases().find((target) => target.key === key);
}

async function isImported(outputPath: string) {
  try {
    await access(getOgOutputAbsolutePath(outputPath));
    return true;
  } catch {
    return false;
  }
}

export async function getOgTargets(): Promise<OgTarget[]> {
  const targets = getOgTargetBases();

  return Promise.all(
    targets.map(async (target) => ({
      ...target,
      imported: await isImported(target.outputPath),
    })),
  );
}
