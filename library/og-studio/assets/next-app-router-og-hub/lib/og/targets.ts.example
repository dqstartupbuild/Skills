import { access } from "node:fs/promises";
import path from "node:path";
import type { OgCardConfig } from "./card";

export type OgTargetGroup = "marketing" | "blog" | "compare" | "tools";

export type OgTargetBase = {
  key: string;
  label: string;
  route: string;
  outputPath: string;
  group: OgTargetGroup;
  config: OgCardConfig;
};

export type OgTarget = OgTargetBase & {
  imported: boolean;
};

