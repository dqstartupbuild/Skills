/* eslint-disable @next/next/no-img-element */
import type { CSSProperties, ReactElement } from "react";

export type OgAccent = "cyan" | "lime" | "magenta";

export type OgHighlight = {
  label: string;
  value: string;
};

export type OgCardConfig = {
  brandName: string;
  brandTagline: string;
  siteLabel: string;
  eyebrow: string;
  title: string;
  description: string;
  accent: OgAccent;
  badge: string;
  chips?: string[];
  highlights: OgHighlight[];
  footer: string;
};

const palette = {
  background: "#050816",
  foreground: "#f7f8fb",
  muted: "#b6c0d4",
  line: "rgba(255, 255, 255, 0.08)",
  surface: "rgba(10, 15, 30, 0.88)",
  accentGlow: {
    cyan: "rgba(38, 218, 248, 0.26)",
    lime: "rgba(214, 255, 51, 0.22)",
    magenta: "rgba(239, 64, 246, 0.22)",
  },
  accentSolid: {
    cyan: "#26daf8",
    lime: "#d6ff33",
    magenta: "#ef40f6",
  },
} as const;

export function truncateCopy(value: string, maxLength: number) {
  if (value.length <= maxLength) {
    return value;
  }

  return `${value.slice(0, maxLength - 1).trimEnd()}...`;
}

export function humanizeLabel(value: string) {
  return value
    .split("-")
    .filter(Boolean)
    .map((segment) => segment.charAt(0).toUpperCase() + segment.slice(1))
    .join(" ");
}

function getHighlightBoxStyle(accent: OgAccent): CSSProperties {
  return {
    display: "flex",
    flexDirection: "column",
    justifyContent: "space-between",
    minHeight: 120,
    padding: "18px 20px",
    borderRadius: 28,
    border: `1px solid ${palette.line}`,
    background: "rgba(255, 255, 255, 0.035)",
    boxShadow: `0 16px 40px ${palette.accentGlow[accent]}`,
  };
}

export function renderOgCard(config: OgCardConfig, iconSrc: string): ReactElement {
  const accentColor = palette.accentSolid[config.accent];

  return (
    <div
      style={{
        width: "100%",
        height: "100%",
        display: "flex",
        position: "relative",
        overflow: "hidden",
        padding: 42,
        backgroundColor: palette.background,
        color: palette.foreground,
      }}
    >
      <div
        style={{
          position: "absolute",
          inset: 0,
          backgroundImage:
            "linear-gradient(180deg, rgba(255,255,255,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px)",
          backgroundSize: "120px 120px",
          opacity: 0.46,
        }}
      />
      <div
        style={{
          position: "absolute",
          inset: 0,
          background: `radial-gradient(circle at 14% 12%, ${palette.accentGlow.cyan}, transparent 32%), radial-gradient(circle at 86% 10%, ${palette.accentGlow.magenta}, transparent 28%), radial-gradient(circle at 52% 94%, ${palette.accentGlow[config.accent]}, transparent 34%)`,
        }}
      />

      <div
        style={{
          display: "flex",
          flex: 1,
          gap: 30,
          borderRadius: 38,
          border: `1px solid ${palette.line}`,
          background: palette.surface,
          padding: "34px 34px 30px",
        }}
      >
        <div style={{ display: "flex", flexDirection: "column", width: 676 }}>
          <div style={{ display: "flex", alignItems: "center", justifyContent: "space-between", marginBottom: 26 }}>
            <div
              style={{
                display: "flex",
                alignItems: "center",
                gap: 14,
                padding: "12px 18px",
                borderRadius: 999,
                border: `1px solid ${palette.line}`,
                background: "rgba(255,255,255,0.05)",
              }}
            >
              <img
                alt={`${config.brandName} app icon`}
                src={iconSrc}
                width={52}
                height={52}
                style={{ borderRadius: 16 }}
              />
              <div style={{ display: "flex", flexDirection: "column", gap: 3 }}>
                <span style={{ fontSize: 15, letterSpacing: "0.24em", textTransform: "uppercase", color: accentColor }}>
                  {config.brandName}
                </span>
                <span style={{ fontSize: 19, fontWeight: 700 }}>{config.brandTagline}</span>
              </div>
            </div>

            <div
              style={{
                display: "flex",
                alignItems: "center",
                padding: "10px 16px",
                borderRadius: 999,
                border: `1px solid ${accentColor}`,
                color: accentColor,
                fontSize: 16,
                fontWeight: 700,
                letterSpacing: "0.14em",
                textTransform: "uppercase",
              }}
            >
              {config.badge}
            </div>
          </div>

          <div style={{ display: "flex", flexDirection: "column", flex: 1, justifyContent: "space-between" }}>
            <div style={{ display: "flex", flexDirection: "column" }}>
              <div
                style={{
                  display: "flex",
                  marginBottom: 18,
                  color: accentColor,
                  fontSize: 18,
                  fontWeight: 700,
                  letterSpacing: "0.22em",
                  textTransform: "uppercase",
                }}
              >
                {config.eyebrow}
              </div>
              <div
                style={{
                  display: "flex",
                  fontSize: 68,
                  lineHeight: 1,
                  letterSpacing: "-0.07em",
                  fontWeight: 800,
                  marginBottom: 22,
                }}
              >
                {truncateCopy(config.title, 90)}
              </div>
              <div
                style={{
                  display: "flex",
                  maxWidth: 620,
                  color: palette.muted,
                  fontSize: 28,
                  lineHeight: 1.34,
                }}
              >
                {truncateCopy(config.description, 180)}
              </div>
            </div>

            <div style={{ display: "flex", flexDirection: "column", gap: 18 }}>
              {config.chips?.length ? (
                <div style={{ display: "flex", flexWrap: "wrap", gap: 10 }}>
                  {config.chips.slice(0, 3).map((chip) => (
                    <span
                      key={chip}
                      style={{
                        display: "flex",
                        alignItems: "center",
                        padding: "10px 16px",
                        borderRadius: 999,
                        border: `1px solid ${palette.line}`,
                        background: "rgba(255,255,255,0.05)",
                        color: palette.foreground,
                        fontSize: 16,
                        fontWeight: 600,
                      }}
                    >
                      {chip}
                    </span>
                  ))}
                </div>
              ) : null}

              <div style={{ display: "flex", alignItems: "center", justifyContent: "space-between" }}>
                <div style={{ display: "flex", fontSize: 17, color: "rgba(247, 248, 251, 0.78)" }}>{config.footer}</div>
                <div style={{ display: "flex", fontSize: 16, color: "rgba(247, 248, 251, 0.48)" }}>
                  {config.siteLabel}
                </div>
              </div>
            </div>
          </div>
        </div>

        <div style={{ display: "flex", flexDirection: "column", flex: 1, gap: 16 }}>
          {config.highlights.slice(0, 3).map((highlight) => (
            <div key={highlight.label} style={getHighlightBoxStyle(config.accent)}>
              <div
                style={{
                  display: "flex",
                  color: accentColor,
                  fontSize: 15,
                  fontWeight: 700,
                  letterSpacing: "0.18em",
                  textTransform: "uppercase",
                  marginBottom: 10,
                }}
              >
                {highlight.label}
              </div>
              <div style={{ display: "flex", color: palette.foreground, fontSize: 25, lineHeight: 1.28, fontWeight: 700 }}>
                {highlight.value}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  );
}
