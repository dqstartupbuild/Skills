import { headers } from "next/headers";
import { notFound } from "next/navigation";
import { OgStudioPreviewClient } from "./OgStudioPreviewClient";
import { getOgTargetByKey, getOgTargets } from "@/lib/og/targets";

function isLocalHost(host: string | null) {
  if (!host) {
    return false;
  }

  const normalizedHost = host.trim().toLowerCase();

  return (
    normalizedHost === "localhost" ||
    normalizedHost.startsWith("localhost:") ||
    normalizedHost === "127.0.0.1" ||
    normalizedHost.startsWith("127.0.0.1:") ||
    normalizedHost === "[::1]" ||
    normalizedHost.startsWith("[::1]:") ||
    normalizedHost === "::1"
  );
}

export default async function OgStudioPreviewPage({
  params,
}: {
  params: Promise<{ key: string }>;
}) {
  const requestHeaders = await headers();

  if (!isLocalHost(requestHeaders.get("host"))) {
    notFound();
  }

  const { key } = await params;
  const target = getOgTargetByKey(key);
  const targetWithStatus = (await getOgTargets()).find((entry) => entry.key === key);

  if (!target || !targetWithStatus) {
    notFound();
  }

  return <OgStudioPreviewClient target={{ ...target, imported: targetWithStatus.imported }} />;
}
