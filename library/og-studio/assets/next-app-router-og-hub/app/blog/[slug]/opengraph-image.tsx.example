import { ImageResponse } from "next/og";

export const size = {
  width: 1200,
  height: 630,
};

export const contentType = "image/png";

type Props = {
  params: Promise<{
    slug: string;
  }>;
};

async function getArticle(slug: string) {
  return {
    title: slug.replace(/-/g, " "),
    kicker: "Blog",
  };
}

export default async function OpenGraphImage({ params }: Props) {
  const { slug } = await params;
  const article = await getArticle(slug);

  return new ImageResponse(
    (
      <div
        style={{
          width: "100%",
          height: "100%",
          display: "flex",
          flexDirection: "column",
          justifyContent: "center",
          padding: 64,
          background: "linear-gradient(135deg, #091021 0%, #14213d 100%)",
          color: "white",
        }}
      >
        <div style={{ fontSize: 28, opacity: 0.72, marginBottom: 16 }}>{article.kicker}</div>
        <div style={{ fontSize: 72, fontWeight: 800, lineHeight: 1.02 }}>{article.title}</div>
      </div>
    ),
    size,
  );
}
