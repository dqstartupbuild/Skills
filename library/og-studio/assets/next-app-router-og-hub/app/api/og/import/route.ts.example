import { NextResponse } from "next/server";
import { writeTargetPngByKey } from "@/lib/og/importer";

export const runtime = "nodejs";

function isLocalHost(host: string | null) {
  if (!host) {
    return false;
  }

  const normalizedHost = host.trim().toLowerCase();

  return (
    normalizedHost === "localhost" ||
    normalizedHost.startsWith("localhost:") ||
    normalizedHost === "127.0.0.1" ||
    normalizedHost.startsWith("127.0.0.1:") ||
    normalizedHost === "[::1]" ||
    normalizedHost.startsWith("[::1]:") ||
    normalizedHost === "::1"
  );
}

export async function POST(request: Request) {
  if (!isLocalHost(request.headers.get("host"))) {
    return NextResponse.json({ error: "Not found" }, { status: 404 });
  }

  const body = await request.json().catch(() => null);
  const key = typeof body?.key === "string" ? body.key : "";
  const dataUrl = typeof body?.dataUrl === "string" ? body.dataUrl : "";

  if (!key || !dataUrl) {
    return NextResponse.json(
      { error: "Expected JSON body with key and dataUrl." },
      { status: 400 },
    );
  }

  const match = dataUrl.match(/^data:image\/png;base64,(.+)$/);

  if (!match?.[1]) {
    return NextResponse.json(
      { error: "Expected a PNG data URL from the browser preview." },
      { status: 400 },
    );
  }

  try {
    const pngBuffer = Buffer.from(match[1], "base64");
    const result = await writeTargetPngByKey(key, pngBuffer);
    return NextResponse.json({ imported: 1, results: [result] });
  } catch (error) {
    return NextResponse.json(
      { error: error instanceof Error ? error.message : "Preview import failed." },
      { status: 500 },
    );
  }
}
